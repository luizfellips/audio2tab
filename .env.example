# Application
APP_NAME=Audio2Tab

# Directories (relative to project root)
SAMPLES_DIR=samples
OUTPUTS_DIR=outputs

# Upload limits
MAX_UPLOAD_MB=50

# Transcription profile
# clean     — real DI / close-mic guitar (minimal processing)
# synthetic — Suno / AI mixes (bandpass + spectral gate + harmonic correction)
TRANSCRIPTION_PROFILE=clean

# Guitar fretboard mapping
MAX_FRET=24
GUITAR_MIN_FREQUENCY_HZ=80
GUITAR_MAX_FREQUENCY_HZ=1400
GUITAR_MIN_MIDI=40
GUITAR_MAX_MIDI=88
PREFERRED_MAX_FRET_STRING1=12

# Preprocessing modes: off | light | synthetic | full
PREPROCESS_MODE=off
ENABLE_AUDIO_PREPROCESSING=false
ENABLE_HPSS=false
ENABLE_STEM_SEPARATION=false
STEREO_MODE=mono
PREPROCESS_HIGHPASS_HZ=70
PREPROCESS_NORMALIZE_PEAK=0.95

# Harmonic correction (auto-enabled by synthetic profile)
HARMONIC_FOLD_ENABLED=false
SEMITONE_SHIMMER_COLLAPSE=false
SEMITONE_SHIMMER_WINDOW_SEC=0.20

# Basic Pitch
BASIC_PITCH_ONSET_THRESHOLD=0.35
BASIC_PITCH_FRAME_THRESHOLD=0.25
BASIC_PITCH_MIN_NOTE_LENGTH_MS=80
BASIC_PITCH_MELODIA_TRICK=true
BASIC_PITCH_MULTIPLE_PITCH_BENDS=false

# Note cleanup
APPLY_GUITAR_RANGE_FILTER=true
# onset = one note per attack cluster (best for riffs); overlap = legacy monophonic; none = skip
MELODY_EXTRACTION_MODE=onset
ONSET_CLUSTER_SEC=0.10
ONSET_CLUSTER_SPLIT_MIN_AMPLITUDE=0.0
SEMITONE_FLAT_BIAS=false
SAME_PITCH_REPEAT_GAP_SEC=0.22
MERGE_CONSECUTIVE_SAME_PITCH_MAX_GAP_SEC=0.0
MERGE_SAME_PITCH_MAX_GAP_SEC=0.05
ENFORCE_MONOPHONIC=false
MONOPHONIC_MODE=melody
MIN_NOTE_VELOCITY=1
MIN_NOTE_AMPLITUDE=0.0
MIN_NOTE_DURATION_SEC=0.0
# off = Basic Pitch lengths; legato = ring each note until the next attack
NOTE_DURATION_MODE=legato
NOTE_LEGATO_GAP_SEC=0.02
NOTE_MAX_DURATION_SEC=0.55
# Trim overlapping ends + gap before next start in notes.json
NOTE_ONSET_SPACING_SEC=0.02
# Minimum gap between consecutive note starts (Basic Pitch onsets can be too tight)
NOTE_MIN_INTER_ONSET_SEC=0.18
AUDIO_RMS_THRESHOLD=0.0
MAX_MELODIC_JUMP_SEMITONES=24
SHORT_NOTE_MAX_DURATION_SEC=0.0
TIGHT_GAP_SEC=0.25
ISOLATED_NOTE_MAX_DURATION_SEC=0.0
ISOLATED_NOTE_MIN_GAP_SEC=0.70

# Tab layout
TAB_COLUMNS_PER_SECOND=8
TAB_MIN_COLUMN_GAP=2
TAB_MAX_COLUMN_GAP=24

# Suno / AI-generated riffs:
# TRANSCRIPTION_PROFILE=synthetic
